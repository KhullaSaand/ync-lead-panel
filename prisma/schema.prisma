generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

model Lead {
  id        String   @id @default(uuid())
  formName  String
  category  String
  source    String
  formData  Json
  status    String   @default("NEW INQUIRY")
  assigned  String?
  createdAt DateTime @default(now())

  @@index([category])
  @@index([createdAt])
  @@index([status])
}
